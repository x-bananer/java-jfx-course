<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="500" prefWidth="400" spacing="12.0" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="module_6_4.controller.NoteController">

    <children>
        <TextField fx:id="titleField" promptText="Title">
         <font>
            <Font name="Microsoft Sans Serif" size="14.0" />
         </font></TextField>
        <TextArea fx:id="contentField" prefHeight="150" promptText="Note">
         <font>
            <Font name="Microsoft Sans Serif" size="14.0" />
         </font></TextArea>
        <Button defaultButton="true" onAction="#addNote" text="Add" textAlignment="CENTER">
         <font>
            <Font size="16.0" />
         </font></Button>
        <Label fx:id="notes" wrapText="true" />
    </children>
   <cursor>
      <Cursor fx:constant="MOVE" />
   </cursor>
</VBox>
